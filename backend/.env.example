# ── Whale Indexer (backend/listener.js) ──
MONAD_RPC=https://rpc.monad.xyz   # Monad mainnet RPC (getLogs capped at 100 blocks)
WS_PORT=8081                      # live whale feed (WebSocket)
HTTP_PORT=8082                    # REST API: /whales /leaderboard /address/:a /health
WHALE_MIN_MON=5                   # minimum trade size (MON) to count as a whale
INCLUDE_STABLES=0                 # 1 = also surface MON/stablecoin whale flow
BACKFILL_BLOCKS=1500              # blocks of recent history scanned at boot
POLL_MS=2000                      # live poll interval
MAX_BLOCK_SPAN=90                 # blocks per getLogs call (<100 RPC limit)
