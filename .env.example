# ── Frontend (Vite) — copy to .env and adjust for your host ──
# Only VITE_-prefixed vars are exposed to the browser build.

# ── Monad indexer (backend/listener.js) ──
# Defaults in src/config/chain.js point at the hosted indexer; override to
# run against your own deployment.
# VITE_INDEXER_HTTP=https://your-monad-indexer.example.com
# VITE_INDEXER_WS=wss://your-monad-indexer.example.com

# ── Solana indexer (backend/solListener.js) ──
# VITE_SOL_INDEXER_HTTP=https://your-solana-indexer.example.com
# VITE_SOL_INDEXER_WS=wss://your-solana-indexer.example.com

# ── Solana RPC (browser-facing) ──
# IMPORTANT for production: the default public RPC (solana-rpc.publicnode.com)
# is rate-limited and will drop trades / balance reads under real traffic.
# Use a dedicated endpoint (Helius / QuickNode / Triton) at launch:
# VITE_SOL_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Note: the Monad browser RPC (rpc.monad.xyz) lives in src/config/chain.js
# (MONAD_MAINNET.rpcUrls). Swap it there for a dedicated Monad RPC at scale.
