# ── Frontend (Vite) — copy to .env and adjust for your host ──
# URL of the whale indexer's WebSocket (live feed) and HTTP API.
# Defaults below match running backend/listener.js locally.
VITE_INDEXER_WS=ws://localhost:8081
VITE_INDEXER_HTTP=http://localhost:8082

# When you deploy the indexer to a server, point these at it, e.g.:
# VITE_INDEXER_WS=wss://your-host.example.com
# VITE_INDEXER_HTTP=https://your-host.example.com
